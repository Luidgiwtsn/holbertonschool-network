#!/usr/bin/env bash
# Configure la resolution IP locale pour localhost et facebook.com

# Modifier la resolution de localhost vers 127.0.0.2 de maniere robuste
sed -i 's/127.0.0.1\s*localhost/127.0.0.2 localhost/g' /etc/hosts

# Ajouter ou mettre a jour la resolution de facebook.com vers 8.8.8.8
if grep -q "facebook.com" /etc/hosts; then
    sed -i 's/.*facebook.com.*/8.8.8.8 facebook.com/' /etc/hosts
else
    echo "8.8.8.8 facebook.com" >> /etc/hosts
fi
