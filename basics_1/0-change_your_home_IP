#!/usr/bin/env bash
# Configure la resolution IP locale pour localhost et facebook.com

# Nettoyer les anciennes configurations pour eviter les doublons
sed -i '/localhost/d' /etc/hosts
sed -i '/facebook.com/d' /etc/hosts

# Ajouter proprement les nouvelles configurations attendues par le checker
echo -e "127.0.0.2 localhost\n8.8.8.8 facebook.com" >> /etc/hosts
