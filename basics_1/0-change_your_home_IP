#!/usr/bin/env bash
# Configure la resolution IP locale pour localhost et facebook.com

# Remplacer strictement la premiere occurrence standard de localhost
sed -i 's/127.0.0.1 localhost/127.0.0.2 localhost/g' /etc/hosts

# Gerer le cas ou c'est separe par une tabulation (frequent sur Ubuntu)
sed -i 's/127.0.0.1\tlocalhost/127.0.0.2 localhost/g' /etc/hosts

# Ajouter ou mettre a jour la resolution de facebook.com
if grep -q "facebook.com" /etc/hosts; then
    sed -i 's/.*facebook.com.*/8.8.8.8 facebook.com/' /etc/hosts
else
    echo "8.8.8.8 facebook.com" >> /etc/hosts
fi
